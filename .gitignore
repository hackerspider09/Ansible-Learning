# Local .terraform directory
.terraform/

# .tfstate files (contain sensitive data and secrets)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files by default as they often contain secrets
*.tfvars
*.tfvars.json

# Variables and override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files for specific environments if desired
# !example.tfvars

# Terraform CLI configuration files
.terraformrc
terraform.rc


*/ansible-ssh-key
*/ansible-ssh-key.pub
nohup.out